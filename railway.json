{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install --upgrade pip setuptools wheel && pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "gunicorn --timeout 300 --workers 1 app:app",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE"
  }
}
